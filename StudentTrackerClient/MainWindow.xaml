<Window x:Class="StudentTracker.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:StudentTracker" xmlns:viewmodels="clr-namespace:StudentTrackerClient.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
		xmlns:controls="clr-namespace:StudentTrackerClient.Controls"
		mc:Ignorable="d"
		Title="MainWindow" Height="450" Width="800">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="10"></ColumnDefinition>
			<ColumnDefinition Width="40"></ColumnDefinition>
			<ColumnDefinition Width="*"></ColumnDefinition>
			<ColumnDefinition Width="10"></ColumnDefinition>
			<ColumnDefinition Width="*"></ColumnDefinition>
			<ColumnDefinition Width="10"></ColumnDefinition>
			<ColumnDefinition Width="*"></ColumnDefinition>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="10"></RowDefinition>
			<RowDefinition Height="35"></RowDefinition>
			<RowDefinition Height="10"></RowDefinition>
			<RowDefinition Height="22"></RowDefinition>
			<RowDefinition Height="*"></RowDefinition>
		</Grid.RowDefinitions>
		<TextBlock x:Name="CurrentTeacherNameLabel" Grid.Column="2" Grid.Row="1"
			   Text="{Binding CurrentTeacher.Name}" FontSize="15" 
			   HorizontalAlignment="Center" TextWrapping="Wrap"></TextBlock>
		<Button x:Name="SwitchTeacherButton" Grid.Column="1" Grid.Row="1" 
				Content="Выход" ToolTip="Сменить текущего пользователя" 
				Command="{Binding SwitchTeacher}" IsEnabled="{Binding IsTeacherPresent}"></Button>
		<ComboBox x:Name="SubjectsComboBox" Grid.Column="4" Grid.Row="1"
				  ItemsSource="{Binding Subjects}" SelectedItem="{Binding CurrentSubject}"></ComboBox>
		<ComboBox x:Name="GroupsComboBox" Grid.Column="6" Grid.Row="1"
				  ItemsSource="{Binding Groups}" SelectedItem="{Binding CurrentGroup}"></ComboBox>
		<ScrollViewer x:Name="SLICScrollViewer" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="4"
					  VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
			<ItemsControl x:Name="StudentsListItemsControl" ItemsSource="{Binding Students}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<TextBox Text="{Binding Name}"></TextBox>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
		<ScrollViewer x:Name="HTSPScrollViewer" Grid.Column="3" Grid.Row="3" 
					 Grid.ColumnSpan="5" Grid.RowSpan="2"
					  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
			<StackPanel x:Name="HeadersTableStackPanel" Orientation="Horizontal">
			</StackPanel>
		</ScrollViewer>
	</Grid>
</Window>
