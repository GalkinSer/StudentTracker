<Page x:Class="StudentTrackerAdminClient.Pages.StudentsTabPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StudentTrackerAdminClient.Pages" xmlns:tabpagesviewmodels="clr-namespace:StudentTrackerAdminClient.ViewModels.TabPagesViewModels" d:DataContext="{d:DesignInstance Type=tabpagesviewmodels:StudentsTabPageViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="StudentsTabPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="0.75*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="150"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="110"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
        </Grid.RowDefinitions>
        <ToolBar x:Name="MainToolBar" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="6">
            <Separator Width="5" Background="Transparent"></Separator>
            <Button x:Name="AddItemButton" Width="25" Command="{Binding AddItem}">
                <Image Source="/Resources/add.png"></Image>
            </Button>
            <Separator Width="5" Background="Transparent"></Separator>
            <Button x:Name="RemoveItemButton" Width="25" Command="{Binding RemoveItem}">
                <Image Source="/Resources/delete.png"></Image>
            </Button>
            <Separator Width="5" Background="Transparent"></Separator>
            <Button x:Name="SaveItemButton" Width="25" Command="{Binding SaveItem}">
                <Image Source="/Resources/save.png"></Image>
            </Button>
        </ToolBar>
        
        <ListBox x:Name="MainListBox" Grid.Row="3" Grid.Column="1" Grid.RowSpan="11"
            ItemsSource="{Binding Students}" SelectedItem="{Binding SelectedStudent}"></ListBox>
        <TextBlock x:Name="StudentNameTextBlock" Grid.Row="3" Grid.Column="3"
            Text="ФИО: " FontSize="25" FontWeight="Bold"></TextBlock>
        <TextBlock x:Name="StudentCardNumberLabelTextBlock" Grid.Row="5" Grid.Column="3"
            Text="Номер студенческого билета: " FontSize="25" FontWeight="Bold"
                   Grid.ColumnSpan="4"></TextBlock>
        <TextBlock x:Name="StudentGroupTextBlock" Grid.Row="11" Grid.Column="3"
            Text="Группа: " FontSize="25" FontWeight="Bold"></TextBlock>
        <TextBlock x:Name="StudentIsRepTextBlock" Grid.Row="9" Grid.Column="3" Grid.ColumnSpan="4"
            Text="Является старостой: " FontSize="25" FontWeight="Bold"></TextBlock>

        <TextBox x:Name="StudentNameTextBox" Grid.Row="3" Grid.Column="5" Grid.ColumnSpan="2"
            Text="{Binding SelectedStudent.Name}" FontSize="20"></TextBox>
        <TextBlock x:Name="StudentCardNumberTextBlock" Grid.Row="7" Grid.Column="3"
                   Grid.ColumnSpan="4" FontSize="25" FontWeight="Bold"
                   Text="{Binding SelectedStudent.StudentCardNumber}"></TextBlock>
        <ComboBox x:Name="StudentGroupComboBox" Grid.Row="11" Grid.Column="5" Grid.ColumnSpan="2"
                  ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedStudent.Group}"></ComboBox>
        <CheckBox x:Name="StudentIsRepCheckBox" Grid.Row="9" Grid.Column="5"
                  HorizontalAlignment="Right" VerticalAlignment="Center"
                  IsChecked="{Binding SelectedStudent.IsRepresentative}"></CheckBox>
    </Grid>
</Page>
