<Page x:Class="StudentTrackerAdminClient.Pages.GroupsTabPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StudentTrackerAdminClient.Pages" xmlns:viewmodels="clr-namespace:StudentTrackerAdminClient.ViewModels" xmlns:tabpagesviewmodels="clr-namespace:StudentTrackerAdminClient.ViewModels.TabPagesViewModels" d:DataContext="{d:DesignInstance Type=tabpagesviewmodels:GroupsTabPageViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GroupsTabPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="0.9*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="0.5*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="0.5*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
        </Grid.RowDefinitions>
        <ToolBar x:Name="MainToolBar" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="7">
            <Separator Width="5" Background="Transparent"></Separator>
            <Button x:Name="AddItemButton" Width="25" Command="{Binding AddItem}">
                <Image Source="/Resources/add.png"></Image>
            </Button>
            <Separator Width="5" Background="Transparent"></Separator>
            <Button x:Name="RemoveItemButton" Width="25" Command="{Binding RemoveItem}">
                <Image Source="/Resources/delete.png"></Image>
            </Button>
            <Separator Width="5" Background="Transparent"></Separator>
            <Button x:Name="SaveItemButton" Width="25" Command="{Binding SaveItem}">
                <Image Source="/Resources/save.png"></Image>
            </Button>
        </ToolBar>
        <ListBox x:Name="MainListBox" Grid.Row="3" Grid.Column="1" Grid.RowSpan="4"
         ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}"></ListBox>
        <TextBlock x:Name="GroupNameTextBlock" Grid.Row="3" Grid.Column="3" 
           Text="Название: " FontSize="25" FontWeight="Bold"></TextBlock>
        
        <TextBox x:Name="GroupNameTextBox" Grid.Row="3" Grid.Column="5" Grid.ColumnSpan="3"
           Text="{Binding SelectedGroup.Name}" FontSize="20"></TextBox>

        <GroupBox x:Name="GroupStudentsGroupBox" Header="Студенты" Grid.Row="5" Grid.Column="3" 
                 Grid.RowSpan="2" Grid.ColumnSpan="3" FontWeight="Bold">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10"></ColumnDefinition>
                    <ColumnDefinition Width="25"></ColumnDefinition>
                    <ColumnDefinition Width="10"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="10"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10"></RowDefinition>
                    <RowDefinition Height="25"></RowDefinition>
                    <RowDefinition Height="10"></RowDefinition>
                    <RowDefinition Height="25"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="10"></RowDefinition>
                </Grid.RowDefinitions>

                <ListBox x:Name="GroupStudentsListBox" Grid.Row="1" Grid.Column="3" 
                 Grid.RowSpan="4" FontWeight="Normal"
                 ItemsSource="{Binding GroupsStudents}" SelectedItem="{Binding SelectedStudent}"></ListBox>
                <Button x:Name="AddStudentButton" Grid.Row="1" Grid.Column="1" Content="+"
                Command="{Binding AddStudent}" IsEnabled="{Binding IsGroupSelected}"></Button>
            </Grid>
        </GroupBox>

        <GroupBox x:Name="GroupSubjectsGroupBox" Header="Предметы" Grid.Row="5" Grid.Column="7" 
                 Grid.RowSpan="2" Grid.ColumnSpan="3" FontWeight="Bold">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10"></ColumnDefinition>
                    <ColumnDefinition Width="25"></ColumnDefinition>
                    <ColumnDefinition Width="10"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="10"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10"></RowDefinition>
                    <RowDefinition Height="25"></RowDefinition>
                    <RowDefinition Height="10"></RowDefinition>
                    <RowDefinition Height="25"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="10"></RowDefinition>
                </Grid.RowDefinitions>

                <ListBox x:Name="GroupSubjectsListBox" Grid.Row="1" Grid.Column="3" Grid.RowSpan="4"
                 ItemsSource="{Binding GroupsSubjects}" FontWeight="Normal"
                 SelectedItem="{Binding SelectedSubject}"></ListBox>
                <Button x:Name="AddSubjectButton" Grid.Row="1" Grid.Column="1" Content="+"
                Command="{Binding AddSubject}" IsEnabled="{Binding IsGroupSelected}"></Button>
                <Button x:Name="RemoveSubjectButton" Grid.Row="3" Grid.Column="1" Content="-"
                Command="{Binding RemoveSubject}" IsEnabled="{Binding IsGroupSelected}"></Button>

            </Grid>
        </GroupBox>

    </Grid>
</Page>
