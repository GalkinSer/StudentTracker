<Page x:Class="StudentTrackerAdminClient.Pages.TeachersTabPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StudentTrackerAdminClient.Pages" xmlns:viewmodels="clr-namespace:StudentTrackerAdminClient.ViewModels" xmlns:tabpagesviewmodels="clr-namespace:StudentTrackerAdminClient.ViewModels.TabPagesViewModels" d:DataContext="{d:DesignInstance Type=tabpagesviewmodels:TeachersTabPageViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TeachersTabPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="0.75*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="125"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
        </Grid.RowDefinitions>
        <ToolBar x:Name="MainToolBar" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5">
            <Separator Width="5" Background="Transparent"></Separator>
            <Button x:Name="AddItemButton" Width="25" Command="{Binding AddItem}">
                <Image Source="/Resources/add.png"></Image>
            </Button>
            <Separator Width="5" Background="Transparent"></Separator>
            <Button x:Name="RemoveItemButton" Width="25" Command="{Binding RemoveItem}">
                <Image Source="/Resources/delete.png"></Image>
            </Button>
            <Separator Width="5" Background="Transparent"></Separator>
            <Button x:Name="SaveItemButton" Width="25" Command="{Binding SaveItem}">
                <Image Source="/Resources/save.png"></Image>
            </Button>
        </ToolBar>
        <ListBox x:Name="MainListBox" Grid.Row="3" Grid.Column="1" Grid.RowSpan="3"
                 ItemsSource="{Binding Teachers}" SelectedItem="{Binding SelectedTeacher}"></ListBox>
        <TextBlock x:Name="TeacherNameTextBlock" Grid.Row="3" Grid.Column="3"
                   Text="ФИО:" FontSize="25" FontWeight="Bold"></TextBlock>

        <TextBox x:Name="TeacherNameTextBox" Grid.Row="3" Grid.Column="5"
                   Text="{Binding SelectedTeacher.Name}" FontSize="20"></TextBox>
        <GroupBox x:Name="GroupStudentsGroupBox" Header="Предметы" Grid.Row="5" Grid.Column="3" 
                 Grid.RowSpan="8" Grid.ColumnSpan="4" FontWeight="Bold">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10"></ColumnDefinition>
                    <ColumnDefinition Width="25"></ColumnDefinition>
                    <ColumnDefinition Width="10"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="10"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10"></RowDefinition>
                    <RowDefinition Height="25"></RowDefinition>
                    <RowDefinition Height="10"></RowDefinition>
                    <RowDefinition Height="25"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="10"></RowDefinition>
                </Grid.RowDefinitions>
                <ListBox x:Name="TeacherSubjectsListBox" Grid.Row="1" Grid.Column="3" Grid.RowSpan="4"
                 ItemsSource="{Binding TeachersSubjects}" SelectedItem="{Binding SelectedSubject}"
                        FontWeight="Normal" ></ListBox>
                <Button x:Name="AddSubjectButton" Grid.Row="1" Grid.Column="1" Content="+"
                Command="{Binding AddSubject}" IsEnabled="{Binding IsTeacherSelected}"></Button>
                <Button x:Name="RemoveSubjectButton" Grid.Row="3" Grid.Column="1" Content="-"
                Command="{Binding RemoveSubject}" IsEnabled="{Binding IsTeacherSelected}"></Button>
            </Grid>
        </GroupBox>

    </Grid>
</Page>
