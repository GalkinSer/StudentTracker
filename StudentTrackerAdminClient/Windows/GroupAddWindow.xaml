<Window x:Class="StudentTrackerAdminClient.Windows.GroupAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentTrackerAdminClient.Windows" xmlns:addwindowsviewmodels="clr-namespace:StudentTrackerAdminClient.ViewModels.AddWindowsViewModels" d:DataContext="{d:DesignInstance Type=addwindowsviewmodels:GroupAddWindowViewModel}"
        mc:Ignorable="d"
        Title="GroupAddWindow" Height="350" Width="300">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="50"></ColumnDefinition>
            <ColumnDefinition Width="25"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="35"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock x:Name="GroupNameTextBlock" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
           Text="Название:" FontSize="14" FontWeight="Bold"
           VerticalAlignment="Center"></TextBlock>
        <TextBlock x:Name="GroupSubjectsTextBlock" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
           Text="Предметы: " FontSize="14" FontWeight="Bold"
           VerticalAlignment="Center"></TextBlock>

        <TextBox x:Name="GroupNameTextBox" Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="4"
           Text="{Binding Group.Name}"></TextBox>
        <ListBox x:Name="GroupSubjectsListBox" Grid.Row="3" Grid.Column="4" Grid.RowSpan="7"
         Grid.ColumnSpan="3"
         ItemsSource="{Binding Subjects}" SelectedItem="{Binding SelectedSubject}"></ListBox>

        <Button x:Name="AddSubjectButton" Content="+" Grid.Row="5" Grid.Column="2"
        Command="{Binding AddSubject}"></Button>
        <Button x:Name="DeleteSubjectButton" Content="-" Grid.Row="7" Grid.Column="2"
        Command="{Binding DeleteSubject}"></Button>

        <Button x:Name="OkButton" Content="OK" Grid.Row="11" Grid.Column="6"
        Command="{Binding Ok}" IsEnabled="{Binding IsOkEnabled}"></Button>
        <Button x:Name="CancelButton" Content="Отмена" Grid.Row="11" Grid.Column="4"
        Command="{Binding Cancel}"></Button>
    </Grid>
</Window>
